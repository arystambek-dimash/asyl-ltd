# Скопируйте в .env и задайте свои значения.
# Суперпользователь создаётся автоматически при первом подъёме Docker.
DOMAIN=asyl-ltd.kz
CERTBOT_EMAIL=admin@asyl-ltd.kz
CERTBOT_STAGING=0

SECRET_KEY=change-me-generate-a-long-random-string
POSTGRES_DB=asyl
POSTGRES_USER=asyl
POSTGRES_PASSWORD=change-me-db-password

ALLOWED_HOSTS=asyl-ltd.kz,www.asyl-ltd.kz,78.40.109.240
CORS_ALLOWED_ORIGINS=https://asyl-ltd.kz,https://www.asyl-ltd.kz
CSRF_TRUSTED_ORIGINS=https://asyl-ltd.kz,https://www.asyl-ltd.kz
NEXT_PUBLIC_API_URL=/api

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASS=change-me
SUPER_ADMIN_RESET_PASSWORD=0

# WireGuard для удалённого доступа к камерам.
# Если камеры в другой LAN-подсети, замените 192.168.1.0/24 на реальную подсеть камер.
WG_SERVERURL=78.40.109.240
WG_SERVERPORT=51820
WG_PEERS=operatorlaptop
WG_PEERDNS=1.1.1.1
WG_INTERNAL_SUBNET=10.13.13.0
WG_ALLOWEDIPS=10.13.13.0/24,192.168.1.0/24
WG_PERSISTENTKEEPALIVE_PEERS=all

# Камеры цеха (go2rtc): RTSP-прокси MediaMTX на ПК с камерами (Tailscale).
CAMERA_HOST=100.109.156.107
CAMERA_USER=viewer
CAMERA_PASS=change-me-viewer-password

# End-to-end camera monitor (MediaMTX -> Tailscale -> go2rtc -> real JPEG frame).
CAMERA_EXPECTED_COUNT=10
CAMERA_MINIMUM_ONLINE_COUNT=5
CAMERA_MONITOR_INTERVAL_SECONDS=30
CAMERA_HEALTH_STALE_SECONDS=180
CAMERA_FAILURE_THRESHOLD=3
CAMERA_DEGRADED_THRESHOLD=3
CAMERA_RECOVERY_THRESHOLD=2

# Optional external incident delivery. Leave blank until a trusted destination
# is configured on the production server; no token should be committed to git.
CAMERA_ALERT_WEBHOOK_URL=
CAMERA_ALERT_WEBHOOK_TOKEN=
CAMERA_ALERT_TELEGRAM_BOT_TOKEN=
CAMERA_ALERT_TELEGRAM_CHAT_ID=
